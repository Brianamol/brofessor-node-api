# ─────────────────────────────────────────────
#  SERVER
# ─────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1

# ─────────────────────────────────────────────
#  DATABASE  (MySQL via Prisma)
# ─────────────────────────────────────────────
DATABASE_URL="mysql://root:rootpassword@localhost:3307/marketplace"

# ─────────────────────────────────────────────
#  REDIS  (cart, sessions, rate limiting)
# ─────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─────────────────────────────────────────────
#  KEYCLOAK  (authentication)
# ─────────────────────────────────────────────
KEYCLOAK_URL=http://localhost:8180
KEYCLOAK_REALM=marketplace
KEYCLOAK_CLIENT_ID=marketplace-backend
KEYCLOAK_CLIENT_SECRET=your-backend-client-secret

# ─────────────────────────────────────────────
#  CLOUDINARY  (image storage)
# ─────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ─────────────────────────────────────────────
#  M-PESA  (Safaricom Daraja API)
# ─────────────────────────────────────────────
MPESA_ENVIRONMENT=sandbox
MPESA_CONSUMER_KEY=your-consumer-key
MPESA_CONSUMER_SECRET=your-consumer-secret
MPESA_SHORTCODE=174379
MPESA_PASSKEY=your-passkey
MPESA_CALLBACK_URL=https://yourdomain.co.ke/api/v1/payments/mpesa/callback
MPESA_RESULT_URL=https://yourdomain.co.ke/api/v1/payments/mpesa/result

# ─────────────────────────────────────────────
#  EMAIL  (Nodemailer)
# ─────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@yourstore.co.ke
SMTP_PASS=your-app-password
EMAIL_FROM="Your Store <noreply@yourstore.co.ke>"

# ─────────────────────────────────────────────
#  FRONTEND
# ─────────────────────────────────────────────
FRONTEND_URL=http://localhost:4200
ALLOWED_ORIGINS=http://localhost:4200,https://yourstore.co.ke

# ─────────────────────────────────────────────
#  RATE LIMITING
# ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
